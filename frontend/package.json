    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0"
  }

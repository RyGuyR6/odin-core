
# OIC-008 — OpenAI Integration Layer
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_PRIMARY_MODEL=gpt-5
OPENAI_ECONOMY_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REQUEST_TIMEOUT=60
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BASE_SECONDS=0.5
OPENAI_PRICING_REGISTRY=
ODIN_LLM_EXPOSE_RAW=false

# Odin Milestone 16 — Prompt & Template Engine
ODIN_PROMPTS_DIR=
ODIN_PROMPT_CACHE_SIZE=256
ODIN_PROMPT_STRICT=true
ODIN_PROMPT_AUTO_RELOAD=false

# Odin Milestone 17 — Conversation & Session Manager
ODIN_CONVERSATIONS_DB=
ODIN_CONVERSATION_HISTORY_LIMIT=40
ODIN_CONVERSATION_CONTEXT_MESSAGES=20
ODIN_CONVERSATION_AUTO_TITLE=true
ODIN_CONVERSATION_SUMMARY_THRESHOLD=30

# Odin Milestone 18 V2 — Agent Runtime
ODIN_AGENTS_DB=
ODIN_AGENT_TIMEOUT_SECONDS=300
ODIN_AGENT_MAX_RETRIES=2
ODIN_AGENT_MAX_WORKFLOW_STEPS=50
ODIN_AGENT_PERSIST_EVENTS=true

# Odin Milestone 19 — Long-Term Memory
ODIN_MEMORY_DB=
ODIN_MEMORY_EMBEDDING_PROVIDER=local-hash
ODIN_MEMORY_EMBEDDING_MODEL=odin-hash-v1
ODIN_MEMORY_EMBEDDING_DIMENSIONS=256
ODIN_MEMORY_CHUNK_SIZE=1200
ODIN_MEMORY_CHUNK_OVERLAP=180
ODIN_MEMORY_SEARCH_LIMIT=10
ODIN_MEMORY_SEARCH_MAX_LIMIT=100
ODIN_MEMORY_AUTO_INDEX_CONVERSATIONS=false
ODIN_TOOL_WORKSPACE_ROOT=.odin-workspaces
ODIN_TOOL_DB=backend/data/tools.db
ODIN_TOOL_TIMEOUT_SECONDS=30
ODIN_TOOL_MAX_TIMEOUT_SECONDS=300
ODIN_TOOL_MAX_OUTPUT_BYTES=1048576
ODIN_TOOL_ALLOW_SHELL=false
ODIN_TOOL_ALLOW_PYTHON=false
ODIN_TOOL_APPROVE_WRITES=true
ODIN_TOOL_APPROVE_SHELL=true
ODIN_TOOL_AUDIT_RETENTION_DAYS=90

# OW-003 Identity & Secure Access
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(64))'
ODIN_AUTH_SECRET=replace-with-a-long-random-secret
ODIN_AUTH_DB=backend/data/odin_auth.db
ODIN_AUTH_ACCESS_MINUTES=15
ODIN_AUTH_REFRESH_DAYS=30
# Set to true in production (automatically applied when ODIN_ENV=production).
ODIN_AUTH_SECURE_COOKIES=false
# Scope cookies to all subdomains. Production: .odincore.net  Local: (empty)
ODIN_AUTH_COOKIE_DOMAIN=

# Odin MCP service URL (used by /api/mcp/status).
# Production: https://mcp.odincore.net
ODIN_MCP_URL=
# Health endpoint for the MCP service.
# Production: https://mcp.odincore.net/health  Fallback: https://odin-mcp.onrender.com/health
ODIN_MCP_HEALTH_URL=
